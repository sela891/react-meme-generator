useEffect(() => {
    async function getImgs() {
      try {
        setIsLoading(true);
        const response = await axios.get('https://api.memegen.link/templates');

        const fetchedOptions = response.data.map((meme) => ({
          value: meme.blank,
          label: meme.name,
        }));

        setOptions(fetchedOptions);
        const doge = fetchedOptions.find((opt) =>
          opt.label.toLowerCase().includes('doge'),
        );

        if (doge) {
          setSelectedOption(doge);
          props.onMemeSelect(doge);
        }
      } catch (err) {
        console.error('Failed to fetch memes:', err);
        setError('Oops! Could not load the memes.');
      } finally {
        setIsLoading(false);
      }
    }


